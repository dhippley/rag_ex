# The directory for Mix dependencies
/_build/
/deps/

# Where 3rd-party dependencies like ExDoc output generated files.
/doc/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
rag_ex-*.tar

# Temporary files, for example, from tests.
/tmp/

# Database files
data/
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.db

# Environment files
.env
.env.local

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db